---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import Faq from '../components/Faq.astro';
import ContactForm from '../components/ContactForm.astro';
import OtherServices from '../components/OtherServices.astro';

const faqItems = [
  {
    q: 'How much does sofa cleaning cost in Buffalo, NY?',
    a: 'Sofa and sectional cleaning starts at $89. The final price depends on the size, construction, fabric and condition of the piece and is confirmed after a photo estimate.',
  },
  {
    q: 'How long will my sofa take to dry?',
    a: 'Most sofas and chairs typically need several hours to dry. Drying time depends on fabric, airflow, humidity, construction and the amount of cleaning required.',
  },
  {
    q: 'Can every stain be removed?',
    a: 'No. Every fabric and stain is different — some stains can be removed completely, while others may only improve. We explain realistic expectations before starting.',
  },
  {
    q: 'Can you help with pet hair and odor concerns?',
    a: 'Yes. Pet hair and light household odor concerns can often be improved during cleaning. Strong or deep-set odors require an in-person or photo assessment, and full removal is not guaranteed.',
  },
  {
    q: 'What should I do before the appointment?',
    a: 'Please remove pillows, blankets and personal items, and clear access around the sofa. You do not need to move heavy furniture.',
  },
  {
    q: 'Which areas do you serve?',
    a: 'Buffalo, Amherst, Williamsville, Clarence, East Amherst, Cheektowaga, Lancaster, Tonawanda, West Seneca, Orchard Park, and Depew.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Sofa & Sectional Cleaning',
  serviceType: 'Upholstery Cleaning',
  url: 'https://freshnestbuffalo.com/sofa-cleaning-buffalo-ny',
  provider: {
    '@id': 'https://freshnestbuffalo.com/#business',
  },
  areaServed: [
    { '@type': 'City', name: 'Buffalo' },
    { '@type': 'City', name: 'Amherst' },
    { '@type': 'City', name: 'Williamsville' },
    { '@type': 'City', name: 'Clarence' },
    { '@type': 'City', name: 'East Amherst' },
    { '@type': 'City', name: 'Cheektowaga' },
    { '@type': 'City', name: 'Lancaster' },
    { '@type': 'City', name: 'Tonawanda' },
    { '@type': 'City', name: 'West Seneca' },
    { '@type': 'City', name: 'Orchard Park' },
    { '@type': 'City', name: 'Depew' },
  ],
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: '89', priceCurrency: 'USD' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://freshnestbuffalo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Sofa Cleaning Buffalo NY', item: 'https://freshnestbuffalo.com/sofa-cleaning-buffalo-ny' },
  ],
};
---

<Layout
  title="Sofa & Couch Cleaning Buffalo, NY | Fresh Nest"
  description="Professional sofa, couch and sectional cleaning in Buffalo. Help with stains, pet hair, spills, odors and everyday buildup. Send photos for a free quote."
  canonical="https://freshnestbuffalo.com/sofa-cleaning-buffalo-ny"
  extraSchemas={[serviceSchema, breadcrumbSchema]}
>
  <div class="hero" id="home">
    <div class="hero-left">
      <div class="badge">Owner-operated · Buffalo, NY</div>
      <h1>Professional<br /><em>Sofa & Couch Cleaning</em><br />in Buffalo, NY</h1>
      <p class="hero-sub">Dark, worn armrests? Spills, pet hair, visible stains or everyday buildup? Send photos and get a clear quote before your appointment.</p>
      <Cta
        buttons={[
          { label: 'Get a Free Photo Quote', href: '#quote', variant: 'primary' },
          { label: 'Call (716) 204-6437', href: 'tel:+17162046437', variant: 'secondary' },
        ]}
      />
      <div class="hero-stats">
        <div><div class="stat-num">$89</div><div class="stat-label">Starting price</div></div>
        <div><div class="stat-num">Photos</div><div class="stat-label">For an accurate quote</div></div>
        <div><div class="stat-num">Free</div><div class="stat-label">Estimates</div></div>
      </div>
    </div>
    <div class="hero-right">
      <img src="/images/owner.png" alt="Owner of Fresh Nest Upholstery Cleaning serving Buffalo, NY" />
    </div>
  </div>

  <section id="pricing" class="bg-white">
    <p class="eyebrow">Starting at $89</p>
    <h2 class="sec-title">Honest, Upfront Starting Price</h2>
    <p class="sec-sub">Final pricing depends on furniture size, construction, fabric, condition, stains, odors and the surfaces being cleaned. Send photos for an exact quote before your appointment.</p>
  </section>

  <section id="why" class="bg-tint">
    <p class="eyebrow">Why it matters</p>
    <h2 class="sec-title">Why Clean Your Sofa Professionally</h2>
    <p class="sec-sub">Sofas absorb more daily wear than almost any other piece of furniture in the house.</p>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card-title">Dirt</div><div class="trust-card-desc">Ground-in dirt settles deep into fabric fibers over time.</div></div>
      <div class="trust-card"><div class="trust-card-title">Body Oils</div><div class="trust-card-desc">Daily use leaves body oils that dull fabric color and texture.</div></div>
      <div class="trust-card"><div class="trust-card-title">Pet Hair</div><div class="trust-card-desc">Pet hair and dander build up in the weave of the fabric.</div></div>
      <div class="trust-card"><div class="trust-card-title">Odors</div><div class="trust-card-desc">Everyday odors accumulate in upholstery fibers over months of use.</div></div>
      <div class="trust-card"><div class="trust-card-title">Dust & Hair</div><div class="trust-card-desc">Dust, hair and everyday debris can collect in cushions, seams and fabric surfaces.</div></div>
      <div class="trust-card"><div class="trust-card-title">Food Spills</div><div class="trust-card-desc">Spills can leave residue and stains if left untreated.</div></div>
      <div class="trust-card"><div class="trust-card-title">Everyday Buildup</div><div class="trust-card-desc">Regular use gradually builds up soil that vacuuming alone can't remove.</div></div>
    </div>
  </section>

  <section id="problems" class="bg-white">
    <p class="eyebrow">What we treat</p>
    <h2 class="sec-title">Common Sofa Problems We Treat</h2>
    <p class="sec-sub">Every fabric and stain responds differently to treatment.</p>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card-title">Dark Armrests</div><div class="trust-card-desc">Dark, worn areas around armrests and head-contact zones from daily use.</div></div>
      <div class="trust-card"><div class="trust-card-title">Food & Drink Spills</div><div class="trust-card-desc">Spot-treated based on fabric type and how long the spill has set.</div></div>
      <div class="trust-card"><div class="trust-card-title">Pet Hair</div><div class="trust-card-desc">Removed during vacuuming and extraction cleaning.</div></div>
      <div class="trust-card"><div class="trust-card-title">Visible Staining</div><div class="trust-card-desc">Treated with targeted pre-treatment before extraction.</div></div>
      <div class="trust-card"><div class="trust-card-title">Everyday Soil & Buildup</div><div class="trust-card-desc">Lifted from deep in the fabric with professional equipment.</div></div>
      <div class="trust-card"><div class="trust-card-title">Household Odor Concerns</div><div class="trust-card-desc">Light odor concerns can often improve with cleaning; stronger concerns are assessed first.</div></div>
    </div>
  </section>

  <section id="included" class="bg-tint">
    <p class="eyebrow">Our process</p>
    <h2 class="sec-title">What's Included</h2>
    <p class="sec-sub">The exact cleaning method is adjusted to the material and condition. A typical sofa cleaning may include:</p>
    <div class="proc-grid">
      <div class="proc"><div class="proc-num">1</div><div class="proc-title">Fabric Inspection</div><div class="proc-desc">Checking fabric and condition before starting.</div></div>
      <div class="proc"><div class="proc-num">2</div><div class="proc-title">Dry Soil Removal</div><div class="proc-desc">Removal of accessible dry soil, crumbs and hair.</div></div>
      <div class="proc"><div class="proc-num">3</div><div class="proc-title">Pre-Treatment</div><div class="proc-desc">Appropriate pre-treatment applied to stains and heavily soiled areas.</div></div>
      <div class="proc"><div class="proc-num">4</div><div class="proc-title">Spot Treatment</div><div class="proc-desc">Standard spot treatment for visible stains.</div></div>
      <div class="proc"><div class="proc-num">5</div><div class="proc-title">Extraction Cleaning</div><div class="proc-desc">Controlled extraction cleaning when appropriate for the material, lifting dirt and residue from the fabric.</div></div>
      <div class="proc"><div class="proc-num">6</div><div class="proc-title">Moisture Extraction</div><div class="proc-desc">Additional moisture extraction to speed up drying.</div></div>
      <div class="proc"><div class="proc-num">7</div><div class="proc-title">Final Inspection</div><div class="proc-desc">Checking results and addressing any remaining concerns.</div></div>
      <div class="proc"><div class="proc-num">8</div><div class="proc-title">Drying Guidance</div><div class="proc-desc">Advice on airflow and drying time before using the sofa again.</div></div>
    </div>
  </section>

  <section id="expectations" class="bg-white">
    <p class="eyebrow">Honesty first</p>
    <h2 class="sec-title">Honest Expectations</h2>
    <div class="guarantee-box">
      <h3><svg class="guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>Realistic Results, Explained Upfront</h3>
      <p>We inspect the material first and explain realistic expectations before cleaning begins.</p>
      <p>If a stain or odor is unlikely to fully come out, we will tell you before the work begins.</p>
    </div>
  </section>

  <section id="drying" class="bg-tint">
    <p class="eyebrow">Drying time</p>
    <h2 class="sec-title">How Long It Takes To Dry</h2>
    <p class="sec-sub">Most sofas and chairs typically need several hours to dry. Drying time depends on fabric, airflow, humidity, construction and the amount of cleaning required.</p>
  </section>

  <section id="areas" class="bg-white">
    <p class="eyebrow">Where we work</p>
    <h2 class="sec-title">Service Area</h2>
    <p class="sec-sub">Sofa cleaning is available throughout Buffalo, NY and the surrounding Western New York suburbs.</p>
    <div class="area-chips">
      <span class="area-chip">Buffalo</span>
      <span class="area-chip">Amherst</span>
      <span class="area-chip">Williamsville</span>
      <span class="area-chip">Clarence</span>
      <span class="area-chip">East Amherst</span>
      <span class="area-chip">Cheektowaga</span>
      <span class="area-chip">Lancaster</span>
      <span class="area-chip">Tonawanda</span>
      <span class="area-chip">West Seneca</span>
      <span class="area-chip">Orchard Park</span>
      <span class="area-chip">Depew</span>
    </div>
    <p class="area-note">Don't see your city? Call or text me. If you're within about 30–40 minutes of Buffalo, I'll usually come to you.</p>
  </section>

  <section id="faq" class="bg-tint">
    <p class="eyebrow">Questions</p>
    <h2 class="sec-title">Frequently Asked Questions</h2>
    <p class="sec-sub">Straight answers before you book.</p>
    <Faq items={faqItems} />
  </section>

  <section id="quote" class="bg-white">
    <p class="eyebrow">Ready to start?</p>
    <h2 class="sec-title">Get Your Sofa Professionally Cleaned</h2>
    <p class="sec-sub">Submit your details first. After submitting, you can text or email photos of your sofa for a more accurate quote.</p>
    <ContactForm defaultService="Sofa & Sectional Cleaning" sourcePage="/sofa-cleaning-buffalo-ny" formId="sofa" />
  </section>

  <OtherServices currentSlug="sofa-cleaning-buffalo-ny" />
</Layout>
