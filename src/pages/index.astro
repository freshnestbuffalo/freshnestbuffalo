---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import Faq from '../components/Faq.astro';
import ContactForm from '../components/ContactForm.astro';

const faqItems = [
  {
    q: 'How much does upholstery cleaning cost in Buffalo, NY?',
    a: 'Prices start at $49 for a chair, $69 for a mattress, $79 for a car interior, and $89 for a sofa or sectional. The final price depends on the size and condition of the piece and is confirmed after a photo estimate.',
  },
  {
    q: 'How long does upholstery take to dry after cleaning?',
    a: 'Drying time depends on the item, fabric, airflow, humidity and cleaning needs. We explain what to realistically expect for your specific piece before starting.',
  },
  {
    q: 'Do you offer same-day service?',
    a: 'Ask about current availability. Same-day appointments are sometimes possible depending on the schedule.',
  },
  {
    q: 'Is the cleaning process safe for kids and pets?',
    a: 'We use a careful cleaning process for homes with children and pets. Keep children and pets off cleaned surfaces until fully dry.',
  },
  {
    q: 'Do I need to prepare anything before you arrive?',
    a: 'Remove loose items, pillows and blankets, and clear access around the item. You do not need to move heavy furniture — we bring the cleaning equipment and solutions.',
  },
  {
    q: 'What areas do you serve near Buffalo, NY?',
    a: 'Buffalo, Amherst, Williamsville, Clarence, Clarence Center, East Amherst, Cheektowaga, Lancaster, Tonawanda, West Seneca, Orchard Park, and Depew.',
  },
  {
    q: 'How do I get a quote?',
    a: "Submit the short form with your contact details and a brief description. After submitting, you can text or email photos for a more accurate quote. We'll review everything and reply with the price and current availability.",
  },
  {
    q: 'What equipment do you use?',
    a: 'Professional Mytee hot water extraction equipment, the same standard used by upholstery cleaning professionals.',
  },
  {
    q: "What if I'm not satisfied with the cleaning?",
    a: "Every fabric and stain is different, so I never promise impossible results — before starting, I'll explain what can realistically be expected. If you're not satisfied, I'll review the issue with you and do my best to make it right.",
  },
  {
    q: 'Do you clean car interiors as well?',
    a: 'Yes, car interior upholstery cleaning is available starting at $79. Final pricing depends on vehicle size, seat material and condition.',
  },
];
---

<Layout
  title="Upholstery Cleaning Buffalo, NY | Fresh Nest"
  description="Stains, spills, pet hair or everyday buildup? Fresh Nest cleans sofas, chairs, mattresses and vehicle upholstery in Buffalo. Send photos for a free quote."
  canonical="https://freshnestbuffalo.com/"
>
  <div class="hero" id="home">
    <div class="hero-left">
      <div class="badge">Owner-operated · Buffalo, NY</div>
      <h1>Professional<br /><em>Upholstery Cleaning</em><br />in Buffalo, NY</h1>
      <p class="hero-sub">Stains, spills, pet hair or everyday buildup? Submit your details, then text or email photos for a clear quote before your appointment.</p>
      <Cta
        buttons={[
          { label: 'Get a Free Quote', href: '/#contact', variant: 'primary' },
          { label: 'Call (716) 204-6437', href: 'tel:+17162046437', variant: 'secondary' },
        ]}
      />
      <div class="hero-stats">
        <div><div class="stat-num">Photos</div><div class="stat-label">Sent after your request</div></div>
        <div><div class="stat-num">Ask</div><div class="stat-label">About current availability</div></div>
        <div><div class="stat-num">Free</div><div class="stat-label">Estimates</div></div>
      </div>
    </div>
    <div class="hero-right">
      <img src="/images/owner.png" alt="Fresh Nest Upholstery Cleaning owner at work in Buffalo NY" />
    </div>
  </div>

  <section id="services" class="bg-white">
    <p class="eyebrow">What we clean</p>
    <h2 class="sec-title">Our Services</h2>
    <p class="sec-sub">Every job is done by the owner. Final price depends on size and condition.</p>
    <div class="svc-grid">
      <article class="svc-card svc-card--sofa">
        <a href="/sofa-cleaning-buffalo-ny" class="svc-card-link" aria-labelledby="svc-name-sofa"><span class="visually-hidden">View Sofa &amp; Sectional Cleaning details</span></a>
        <div class="svc-card-name" id="svc-name-sofa">Sofa &<br />Sectional</div>
        <div class="svc-card-price">Starts at $89</div>
        <div class="svc-card-desc">Final price depends on size and condition.</div>
        <img src="/images/sofa.png" alt="Sofa and sectional upholstery cleaning icon" class="svc-card-img" width="120" height="120" loading="lazy" />
        <a href="/sofa-cleaning-buffalo-ny" class="btn-quote">View Service <span class="quote-arrow">→</span></a>
      </article>
      <article class="svc-card">
        <a href="/chair-cleaning-buffalo-ny" class="svc-card-link" aria-labelledby="svc-name-chair"><span class="visually-hidden">View Chair &amp; Armchair Cleaning details</span></a>
        <div class="svc-card-name" id="svc-name-chair">Chair &<br />Armchair</div>
        <div class="svc-card-price">Starts at $49</div>
        <div class="svc-card-desc">Final price depends on size and condition.</div>
        <img src="/images/chair.png" alt="Chair and armchair upholstery cleaning icon" class="svc-card-img" width="120" height="120" loading="lazy" />
        <a href="/chair-cleaning-buffalo-ny" class="btn-quote">View Service <span class="quote-arrow">→</span></a>
      </article>
      <article class="svc-card">
        <a href="/mattress-cleaning-buffalo-ny" class="svc-card-link" aria-labelledby="svc-name-mattress"><span class="visually-hidden">View Mattress Cleaning details</span></a>
        <div class="svc-card-name" id="svc-name-mattress">Mattress<br />Cleaning</div>
        <div class="svc-card-price">Starts at $69</div>
        <div class="svc-card-desc">Final price depends on size and condition.</div>
        <img src="/images/mattress.png" alt="Mattress upholstery cleaning icon" class="svc-card-img" width="120" height="120" loading="lazy" />
        <a href="/mattress-cleaning-buffalo-ny" class="btn-quote">View Service <span class="quote-arrow">→</span></a>
      </article>
      <article class="svc-card">
        <a href="/car-interior-cleaning-buffalo-ny" class="svc-card-link" aria-labelledby="svc-name-car"><span class="visually-hidden">View Car Interior Cleaning details</span></a>
        <div class="svc-card-name" id="svc-name-car">Car Interior<br />Cleaning</div>
        <div class="svc-card-price">Starts at $79</div>
        <div class="svc-card-desc">Final price depends on size and condition.</div>
        <img src="/images/car.png" alt="Car interior upholstery cleaning icon" class="svc-card-img" width="120" height="120" loading="lazy" />
        <a href="/car-interior-cleaning-buffalo-ny" class="btn-quote">View Service <span class="quote-arrow">→</span></a>
      </article>
    </div>
  </section>

  <section id="trust" class="bg-white">
    <p class="eyebrow">Why Fresh Nest</p>
    <h2 class="sec-title">Built On Trust, Not Promises</h2>
    <p class="sec-sub">What you're actually getting when you book a cleaning.</p>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card-title">Owner-Operated</div><div class="trust-card-desc">Every job is done personally by the owner — not a rotating crew.</div></div>
      <div class="trust-card"><div class="trust-card-title">Professional Equipment</div><div class="trust-card-desc">Mytee hot water extraction equipment, the professional-grade standard.</div></div>
      <div class="trust-card"><div class="trust-card-title">Products For The Job</div><div class="trust-card-desc">Products selected for the material and cleaning need — not a one-size-fits-all solution.</div></div>
      <div class="trust-card"><div class="trust-card-title">Careful Around Kids &amp; Pets</div><div class="trust-card-desc">A careful cleaning process for homes with children and pets. Keep them off cleaned surfaces until fully dry.</div></div>
      <div class="trust-card"><div class="trust-card-title">Transparent Pricing</div><div class="trust-card-desc">Price confirmed upfront from photos — no surprises on arrival.</div></div>
      <div class="trust-card"><div class="trust-card-title">Quick Response</div><div class="trust-card-desc">We reply as soon as possible. Ask about current availability.</div></div>
      <div class="trust-card"><div class="trust-card-title">Free Estimates</div><div class="trust-card-desc">No cost and no obligation to find out your price.</div></div>
    </div>
    <div class="guarantee-box">
      <h3><svg class="guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>Honest Expectations</h3>
      <p>We inspect the material first and explain realistic expectations before cleaning.</p>
      <p>If a stain or odor is unlikely to fully come out, we will tell you before the work begins.</p>
    </div>
  </section>

  <section id="gallery" class="bg-tint">
    <p class="eyebrow">Results</p>
    <h2 class="sec-title">Before & After</h2>
    <p class="sec-sub">Real results from real clients in Buffalo, NY.</p>
    <div class="ba-grid">
      <div class="ba-card">
        <div class="ba-imgs">
          <div class="ba-side"><img src="/images/chair1-before.jpg" alt="Chair before upholstery cleaning in Buffalo, NY" loading="lazy" /><div class="ba-lbl">Before</div></div>
          <div class="ba-side"><img src="/images/chair1-after.jpg" alt="Chair after professional upholstery cleaning in Buffalo, NY" loading="lazy" /><div class="ba-lbl">After</div></div>
        </div>
        <div class="ba-cap">Chair cleaning · Buffalo, NY</div>
      </div>
      <div class="ba-card">
        <div class="ba-imgs">
          <div class="ba-side"><img src="/images/chair2-before.jpg" alt="Armchair before upholstery cleaning in Amherst, NY" loading="lazy" /><div class="ba-lbl">Before</div></div>
          <div class="ba-side"><img src="/images/chair2-after.jpg" alt="Armchair after professional upholstery cleaning in Amherst, NY" loading="lazy" /><div class="ba-lbl">After</div></div>
        </div>
        <div class="ba-cap">Armchair cleaning · Amherst, NY</div>
      </div>
      <div class="ba-card">
        <div class="ba-imgs">
          <div class="ba-side"><img src="/images/chair3-before.jpg" alt="Chair before upholstery cleaning in Cheektowaga, NY" loading="lazy" /><div class="ba-lbl">Before</div></div>
          <div class="ba-side"><img src="/images/chair3-after.jpg" alt="Chair after professional upholstery cleaning in Cheektowaga, NY" loading="lazy" /><div class="ba-lbl">After</div></div>
        </div>
        <div class="ba-cap">Chair cleaning · Cheektowaga, NY</div>
      </div>
    </div>
  </section>

  <section id="process" class="bg-white">
    <p class="eyebrow">How it works</p>
    <h2 class="sec-title">4 Simple Steps</h2>
    <div class="proc-grid">
      <div class="proc"><div class="proc-num">1</div><div class="proc-title">Submit Your Request</div><div class="proc-desc">Fill out the short form with your contact details and a brief description of the item.</div></div>
      <div class="proc"><div class="proc-num">2</div><div class="proc-title">Send Photos</div><div class="proc-desc">After submitting, text or email a few clear photos, including any stains or problem areas.</div></div>
      <div class="proc"><div class="proc-num">3</div><div class="proc-title">Get Your Quote</div><div class="proc-desc">We review your information and photos, then reply with the price and current availability.</div></div>
      <div class="proc"><div class="proc-num">4</div><div class="proc-title">I Come to You</div><div class="proc-desc">I arrive with the equipment and cleaning solutions. Please remove loose items and clear access around the piece.</div></div>
    </div>
  </section>

  <section id="faq" class="bg-tint">
    <p class="eyebrow">Questions</p>
    <h2 class="sec-title">Frequently Asked Questions</h2>
    <p class="sec-sub">Straight answers before you book.</p>
    <Faq items={faqItems} />
  </section>

  <section id="areas" class="bg-white">
    <p class="eyebrow">Where we work</p>
    <h2 class="sec-title">Service Area</h2>
    <p class="sec-sub">Fresh Nest provides upholstery cleaning throughout Buffalo, NY and the surrounding Western New York suburbs. If your town isn't listed below, call or text to check availability.</p>
    <div class="area-chips">
      <span class="area-chip">Buffalo</span>
      <span class="area-chip">Amherst</span>
      <span class="area-chip">Williamsville</span>
      <span class="area-chip">Clarence</span>
      <span class="area-chip">Clarence Center</span>
      <span class="area-chip">East Amherst</span>
      <span class="area-chip">Cheektowaga</span>
      <span class="area-chip">Lancaster</span>
      <span class="area-chip">Tonawanda</span>
      <span class="area-chip">West Seneca</span>
      <span class="area-chip">Orchard Park</span>
      <span class="area-chip">Depew</span>
    </div>
    <p class="area-note">Don't see your city? Call or text me. If you're within about 30–40 minutes of Buffalo, I'll usually come to you.</p>
  </section>

  <section id="contact" class="bg-tint">
    <p class="eyebrow">Get in touch</p>
    <div class="contact-wrap">
      <div class="contact-info">
        <h2>Get Your Free Quote</h2>
        <p>Send your details first. After submitting, you can text or email photos for a more accurate quote. Serving Buffalo and surrounding areas.</p>
        <a href="tel:+17162046437" class="contact-tel">(716) 204-6437</a>
        <p class="contact-note">Call or text — we reply as soon as possible</p>
        <a href="mailto:freshnestbuffalo@gmail.com" class="contact-email">freshnestbuffalo@gmail.com</a>
      </div>
      <ContactForm sourcePage="/" formId="home" />
    </div>
  </section>
</Layout>
