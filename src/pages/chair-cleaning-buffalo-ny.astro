---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
import Faq from '../components/Faq.astro';
import ContactForm from '../components/ContactForm.astro';
import OtherServices from '../components/OtherServices.astro';

const faqItems = [
  {
    q: 'How much does chair cleaning cost in Buffalo, NY?',
    a: 'Chair and armchair cleaning starts at $49. The final price depends on chair size, construction, fabric, condition and stains, confirmed after a photo estimate.',
  },
  {
    q: 'Do you clean recliners and armchairs?',
    a: 'Yes. Recliners and chairs with complex construction are assessed from photos before pricing.',
  },
  {
    q: 'Can dark armrests and seat stains be improved?',
    a: 'Often, yes. Results depend on the fabric type and how long the staining or darkening has set — we explain realistic expectations before starting.',
  },
  {
    q: 'How long will the chair take to dry?',
    a: 'Most chairs typically need several hours to dry. Drying time depends on fabric, airflow, humidity, construction and the amount of cleaning required.',
  },
  {
    q: 'Can all chair fabrics be cleaned?',
    a: 'Most upholstery fabrics can be cleaned, but the right method depends on the material. Send photos so we can assess the fabric and confirm before your appointment.',
  },
  {
    q: 'Do you clean more than one chair per visit?',
    a: "Yes. Send photos of everything you'd like cleaned and we'll include it in your quote.",
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Chair & Armchair Cleaning',
  serviceType: 'Upholstery Cleaning',
  url: 'https://freshnestbuffalo.com/chair-cleaning-buffalo-ny',
  provider: {
    '@id': 'https://freshnestbuffalo.com/#business',
  },
  areaServed: [
    { '@type': 'City', name: 'Buffalo' },
    { '@type': 'City', name: 'Amherst' },
    { '@type': 'City', name: 'Williamsville' },
    { '@type': 'City', name: 'Clarence' },
    { '@type': 'City', name: 'East Amherst' },
    { '@type': 'City', name: 'Cheektowaga' },
    { '@type': 'City', name: 'Lancaster' },
    { '@type': 'City', name: 'Tonawanda' },
    { '@type': 'City', name: 'West Seneca' },
    { '@type': 'City', name: 'Orchard Park' },
    { '@type': 'City', name: 'Depew' },
  ],
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', minPrice: '49', priceCurrency: 'USD' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://freshnestbuffalo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Chair Cleaning Buffalo NY', item: 'https://freshnestbuffalo.com/chair-cleaning-buffalo-ny' },
  ],
};
---

<Layout
  title="Chair & Armchair Cleaning Buffalo, NY | Fresh Nest"
  description="Professional chair, armchair and recliner upholstery cleaning in Buffalo. Help with dark armrests, seat stains, spills and everyday buildup. From $49."
  canonical="https://freshnestbuffalo.com/chair-cleaning-buffalo-ny"
  extraSchemas={[serviceSchema, breadcrumbSchema]}
>
  <div class="hero" id="home">
    <div class="hero-left">
      <div class="badge">Owner-operated · Buffalo, NY</div>
      <h1>Professional<br /><em>Chair & Armchair Cleaning</em><br />in Buffalo, NY</h1>
      <p class="hero-sub">Darkened armrests, heavily used seat cushions, spills, visible stains, pet hair or fabric concerns? Send photos and get a clear quote before your appointment.</p>
      <Cta
        buttons={[
          { label: 'Get a Free Photo Quote', href: '#quote', variant: 'primary' },
          { label: 'Call (716) 204-6437', href: 'tel:+17162046437', variant: 'secondary' },
        ]}
      />
      <div class="hero-stats">
        <div><div class="stat-num">$49</div><div class="stat-label">Starting price</div></div>
        <div><div class="stat-num">Photos</div><div class="stat-label">For an accurate quote</div></div>
        <div><div class="stat-num">Free</div><div class="stat-label">Estimates</div></div>
      </div>
    </div>
    <div class="hero-right">
      <img src="/images/owner.png" alt="Owner of Fresh Nest Upholstery Cleaning serving Buffalo, NY" />
    </div>
  </div>

  <section id="pricing" class="bg-white">
    <p class="eyebrow">Starting at $49</p>
    <h2 class="sec-title">Honest, Upfront Starting Price</h2>
    <p class="sec-sub">Final pricing depends on chair size, construction, fabric, condition, stains and the surfaces being cleaned. Send photos for an exact quote before your appointment.</p>
  </section>

  <section id="why" class="bg-tint">
    <p class="eyebrow">Why it matters</p>
    <h2 class="sec-title">Why Clean Your Chair Professionally</h2>
    <p class="sec-sub">Chairs and armchairs see concentrated daily wear, especially on arms and seat cushions.</p>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card-title">Dark Armrests</div><div class="trust-card-desc">Repeated contact darkens armrests and headrest areas over time.</div></div>
      <div class="trust-card"><div class="trust-card-title">Seat Wear</div><div class="trust-card-desc">The most-used cushion typically shows soiling first.</div></div>
      <div class="trust-card"><div class="trust-card-title">Pet Hair</div><div class="trust-card-desc">Pet hair and dander build up in the weave of the fabric.</div></div>
      <div class="trust-card"><div class="trust-card-title">Food & Drink Spills</div><div class="trust-card-desc">Spills can leave residue and stains if left untreated.</div></div>
      <div class="trust-card"><div class="trust-card-title">Fabric Concerns</div><div class="trust-card-desc">Different fabrics respond differently to cleaning methods.</div></div>
      <div class="trust-card"><div class="trust-card-title">Everyday Buildup</div><div class="trust-card-desc">Regular use gradually builds up soil that vacuuming alone can't remove.</div></div>
    </div>
  </section>

  <section id="problems" class="bg-white">
    <p class="eyebrow">What we treat</p>
    <h2 class="sec-title">Common Chair Problems We Treat</h2>
    <p class="sec-sub">Every fabric and stain responds differently to treatment.</p>
    <div class="trust-grid">
      <div class="trust-card"><div class="trust-card-title">Darkened Armrests</div><div class="trust-card-desc">Treated with targeted pre-treatment and extraction cleaning.</div></div>
      <div class="trust-card"><div class="trust-card-title">Heavily Used Seat Cushions</div><div class="trust-card-desc">Deep-cleaned to lift soil built up from regular use.</div></div>
      <div class="trust-card"><div class="trust-card-title">Food & Drink Spills</div><div class="trust-card-desc">Spot-treated based on fabric type and stain age.</div></div>
      <div class="trust-card"><div class="trust-card-title">Visible Stains</div><div class="trust-card-desc">Pre-treated and spot-cleaned based on fabric and stain type.</div></div>
      <div class="trust-card"><div class="trust-card-title">Pet Hair</div><div class="trust-card-desc">Removed during vacuuming and extraction cleaning.</div></div>
      <div class="trust-card"><div class="trust-card-title">Fabric Concerns</div><div class="trust-card-desc">Assessed from photos so the right method is used for your chair.</div></div>
    </div>
  </section>

  <section id="included" class="bg-tint">
    <p class="eyebrow">Our process</p>
    <h2 class="sec-title">What's Included</h2>
    <p class="sec-sub">The exact cleaning method is adjusted to the material and condition. A typical chair cleaning may include:</p>
    <div class="proc-grid">
      <div class="proc"><div class="proc-num">1</div><div class="proc-title">Inspection</div><div class="proc-desc">Checking fabric and condition before starting.</div></div>
      <div class="proc"><div class="proc-num">2</div><div class="proc-title">Dry-Soil & Hair Removal</div><div class="proc-desc">Removal of accessible dry soil and hair.</div></div>
      <div class="proc"><div class="proc-num">3</div><div class="proc-title">Pre-Treatment</div><div class="proc-desc">Appropriate pre-treatment applied to stains and heavily soiled areas.</div></div>
      <div class="proc"><div class="proc-num">4</div><div class="proc-title">Spot Treatment</div><div class="proc-desc">Standard spot treatment for visible stains.</div></div>
      <div class="proc"><div class="proc-num">5</div><div class="proc-title">Extraction Cleaning</div><div class="proc-desc">Controlled extraction cleaning when appropriate for the material, lifting dirt and residue from the fabric.</div></div>
      <div class="proc"><div class="proc-num">6</div><div class="proc-title">Moisture Extraction</div><div class="proc-desc">Additional moisture extraction to speed up drying.</div></div>
      <div class="proc"><div class="proc-num">7</div><div class="proc-title">Final Inspection</div><div class="proc-desc">Checking results and addressing any remaining concerns.</div></div>
      <div class="proc"><div class="proc-num">8</div><div class="proc-title">Drying Guidance</div><div class="proc-desc">Advice on airflow and drying time before using the chair again.</div></div>
    </div>
  </section>

  <section id="expectations" class="bg-white">
    <p class="eyebrow">Honesty first</p>
    <h2 class="sec-title">Honest Expectations</h2>
    <div class="guarantee-box">
      <h3><svg class="guarantee-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>Realistic Results, Explained Upfront</h3>
      <p>We inspect the material first and explain realistic expectations before cleaning begins.</p>
      <p>If a stain or odor is unlikely to fully come out, we will tell you before the work begins.</p>
      <p>Recliners and chairs with complex construction are assessed from photos before pricing.</p>
    </div>
  </section>

  <section id="drying" class="bg-tint">
    <p class="eyebrow">Drying time</p>
    <h2 class="sec-title">How Long It Takes To Dry</h2>
    <p class="sec-sub">Most sofas and chairs typically need several hours to dry. Drying time depends on fabric, airflow, humidity, construction and the amount of cleaning required.</p>
  </section>

  <section id="areas" class="bg-white">
    <p class="eyebrow">Where we work</p>
    <h2 class="sec-title">Service Area</h2>
    <p class="sec-sub">Chair cleaning is available throughout Buffalo, NY and the surrounding Western New York suburbs.</p>
    <div class="area-chips">
      <span class="area-chip">Buffalo</span>
      <span class="area-chip">Amherst</span>
      <span class="area-chip">Williamsville</span>
      <span class="area-chip">Clarence</span>
      <span class="area-chip">East Amherst</span>
      <span class="area-chip">Cheektowaga</span>
      <span class="area-chip">Lancaster</span>
      <span class="area-chip">Tonawanda</span>
      <span class="area-chip">West Seneca</span>
      <span class="area-chip">Orchard Park</span>
      <span class="area-chip">Depew</span>
    </div>
    <p class="area-note">Don't see your city? Call or text me. If you're within about 30–40 minutes of Buffalo, I'll usually come to you.</p>
  </section>

  <section id="faq" class="bg-tint">
    <p class="eyebrow">Questions</p>
    <h2 class="sec-title">Frequently Asked Questions</h2>
    <p class="sec-sub">Straight answers before you book.</p>
    <Faq items={faqItems} />
  </section>

  <section id="quote" class="bg-white">
    <p class="eyebrow">Ready to start?</p>
    <h2 class="sec-title">Get Your Chair Professionally Cleaned</h2>
    <p class="sec-sub">Send photos of your chair and we'll reply as soon as possible with a price.</p>
    <ContactForm defaultService="Chair & Armchair Cleaning" sourcePage="/chair-cleaning-buffalo-ny" formId="chair" />
  </section>

  <OtherServices currentSlug="chair-cleaning-buffalo-ny" />
</Layout>
