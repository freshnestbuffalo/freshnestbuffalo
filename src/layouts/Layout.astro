---
import Seo from '../components/Seo.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  robots?: string;
  extraSchemas?: Record<string, unknown>[];
}

const { title, description, canonical, ogImage, robots, extraSchemas = [] } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <Seo title={title} description={description} canonical={canonical} ogImage={ogImage} robots={robots} />
  <LocalBusinessSchema />
  {extraSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body>
  <Nav />
  <slot />
  <Footer />
  <StickyCta />
</body>
</html>
