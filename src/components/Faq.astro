---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
  emitSchema?: boolean;
}

const { items, emitSchema = true } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<div class="faq-list">
  {items.map((item) => (
    <details class="faq-item">
      <summary>{item.q}</summary>
      <p>{item.a}</p>
    </details>
  ))}
</div>

{emitSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
